rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isGodAdmin() {
      // Bootstrap admins — can write config/adminPerms to grant delegated admins.
      // Keep more than one so losing access to a single address doesn't lock out governance.
      return isSignedIn() && request.auth.token.email in [
        'hearn.tenny@icloud.com'
      ];
    }

    function isAdmin() {
      // Delegated admins live in config/adminEmails — that's where the client
      // writes via admin.js:saveAdminEmails. An earlier version of these rules
      // referenced a `config/adminPerms` doc that the app never creates, so
      // delegated admins were silently blocked from every admin write.
      return isGodAdmin() || (
        isSignedIn()
        && exists(/databases/$(database)/documents/config/adminEmails)
        && request.auth.token.email in get(/databases/$(database)/documents/config/adminEmails).data.emails
      );
    }

    match /users/{userId} {
      // Any signed-in user may read profiles (leaderboards, team views).
      // Owner has full write. Admins may only update the coachPro*
      // entitlement fields — used by the Pro Requests admin tab to grant
      // or revoke Coach Pro on a specific user without the user having to
      // re-sign-in for the change to take effect.
      allow read: if isSignedIn();
      allow create, delete: if isOwner(userId);
      allow update: if isOwner(userId) || (
        isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'coachProActive', 'coachProExempt', 'coachProRequestStatus',
          'coachProGrantedAt', 'coachProGrantedBy', 'coachProRevokedAt'
        ])
      ) || (
        // Head coach of a team may flip isCoach on a member of that same
        // team — the only field they can touch on someone else's profile.
        // "Head coach" = the user who created the team document.
        isSignedIn()
        && resource.data.teamId is string
        && request.auth.uid == get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.createdBy
        && userId in get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.members
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isCoach'])
      ) || (
        // Head coach can also assign / change a team member's active plan.
        // Only `activePlanId` is writeable through this path.
        isSignedIn()
        && resource.data.teamId is string
        && request.auth.uid == get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.createdBy
        && userId in get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.members
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['activePlanId'])
      );

      match /workouts/{workoutId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
        // Health-sync webhook writes via firebase-admin, which bypasses rules.
      }

      match /workout_routes/{workoutId} {
        // Imported route polylines (Garmin GPX/TCX, future Fitbit, etc.).
        // Owner reads + writes; teammates can read so the team feed can
        // render route maps.
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }

      match /checklist/{dateKey} {
        allow write: if isOwner(userId);
        // Coaches need to read checklist data to compute plan compliance
        // for athletes on their team. Read is broader than write so the
        // drill-in can show "4 of 6 sessions ticked this week."
        allow read: if isOwner(userId)
          || isAdmin()
          || (
            isSignedIn()
            && exists(/databases/$(database)/documents/users/$(userId))
            && get(/databases/$(database)/documents/users/$(userId)).data.teamId is string
            && (
              request.auth.uid == get(/databases/$(database)/documents/teams/$(get(/databases/$(database)/documents/users/$(userId)).data.teamId)).data.createdBy
              || request.auth.uid in get(/databases/$(database)/documents/teams/$(get(/databases/$(database)/documents/users/$(userId)).data.teamId)).data.coaches
            )
          );
      }

      match /customPlans/{planId} {
        allow read, write: if isOwner(userId);
      }

      match /raceLogs/{logId} {
        allow read, write: if isOwner(userId);
      }

      match /planOverrides/{planId} {
        // Reschedules of plan workouts when the athlete skips a day.
        // Owner-only — no coach/team visibility yet.
        allow read, write: if isOwner(userId);
      }

      match /raceResults/{resultId} {
        // Personal race results — owner-only.
        allow read, write: if isOwner(userId);
      }

      match /devices/{tokenId} {
        // Push notification tokens registered by the iOS app.
        allow read, write: if isOwner(userId);
      }
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      // Creator must put themselves in members (or be an admin creating on someone's behalf).
      // Prevents creating orphan teams with empty members arrays that no one can modify.
      allow create: if isSignedIn()
        && (request.auth.uid in request.resource.data.members || isAdmin());
      // Members may update, but cannot empty the members array (would lock everyone out).
      // Non-members may add exactly themselves (self-join via team code), and only to
      // the `members` field — they can't rename the team or alter other fields.
      allow update: if (
        isSignedIn()
        && request.resource.data.members.size() > 0
        && (
          request.auth.uid in resource.data.members
          ||
          (
            request.auth.uid in request.resource.data.members
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
          )
        )
      ) || isAdmin();
      allow delete: if (isSignedIn() && request.auth.uid in resource.data.members) || isAdmin();

      match /sharedPlans/{planId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.members;
      }

      // Lightweight broadcast notifications written by coaches (e.g. roster
      // updates during race day). Any team member can read; only members
      // can write. Audit found writes were silently failing — now allowed.
      match /alerts/{alertId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.members;
      }

      // Team chat / activity feed.
      // Schema: teams/{teamId}/chat/{messageId}
      //   uid, displayName, text, kind, createdAt
      //   kind: 'chat' (athlete chat), 'workout' (auto-post), 'coach' (broadcast),
      //         'system' (joined/left)
      //   broadcastPush: true if a coach asked iOS to push this message
      // Rules:
      //   - Read: any team member
      //   - Create: any team member, but uid must be self (no impersonation)
      //   - Update: only the author can edit their own (e.g. soft-delete)
      //     Coaches can flag any message as moderated (kind: 'coach' updates only)
      //   - Delete: author or head coach
      match /chat/{messageId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.members;
        allow create: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.members
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500;
        allow update: if isSignedIn()
          && (resource.data.uid == request.auth.uid
              || request.auth.uid == get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy);
        allow delete: if isSignedIn()
          && (resource.data.uid == request.auth.uid
              || request.auth.uid == get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy
              || isAdmin());
      }

      // Subteam hierarchy: a head coach (the team's createdBy user) can
      // carve their team into named subteams (e.g. "Venom") and assign a
      // sub-coach. Athletes only see their own subteam's leaderboard.
      // Schema:
      //   teams/{teamId}/subteams/{subteamId}
      //     name: string
      //     subCoachUid: string (optional)
      //     members: [uid, ...]
      //     createdAt, updatedAt: serverTimestamp
      match /subteams/{subteamId} {
        // Everyone signed in can read so the leaderboard knows where each
        // member sits — filter UI does the visibility cut. (Cross-subteam
        // read is the same scope as cross-team-member read today.)
        allow read: if isSignedIn();
        // Only the head coach (team creator) OR an admin can write subteams.
        // Sub-coaches can update their own subteam (members + name) but
        // cannot create new subteams or reassign the sub-coach role.
        allow create, delete: if isAdmin()
          || (isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy);
        allow update: if isAdmin()
          || (isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy)
          || (isSignedIn() && resource.data.subCoachUid is string && request.auth.uid == resource.data.subCoachUid
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'members', 'updatedAt']));
      }
    }

    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /global_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coach_pro_requests/{uid} {
      // Coach Pro upgrade requests. Doc ID = user uid so each user has at
      // most one outstanding request. User creates/reads their own; admin
      // reads all + flips status (approved/exempt/denied) on review.
      allow read, create: if isOwner(uid);
      allow read, update, delete: if isAdmin();
    }

    match /league_requests/{requestId} {
      // Submitted by a coach when they want to start a new league. Admin
      // approves manually by creating the corresponding leagues/{id} doc.
      // Audit found this collection had no rules at all — writes were
      // silently denied.
      allow create: if isSignedIn()
        && request.resource.data.requestedBy == request.auth.uid;
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.requestedBy == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /approved_clubs/{clubId} {
      // Public list of approved clubs — used by the signup screen team
      // dropdown and the team-search UI. Anyone signed in can read; only
      // admins can approve a new club.
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /team_requests/{requestId} {
      // Coach signup requests for new teams. Coach creates one; admin
      // reads + approves/denies. We don't restrict the creator field at
      // create time — relying on the email field being self-attested
      // because there's no harm in a duplicate request.
      allow read, write: if isAdmin();
      allow create: if isSignedIn();
      allow read, delete: if isSignedIn() && resource.data.coachUid == request.auth.uid;
    }

    match /leagues/{leagueId} {
      // Cross-team / cross-school leagues. Anyone signed in reads to
      // see standings. Admin can do anything; the league creator can
      // update or delete their own league (audit found these were
      // silently failing).
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.createdBy == request.auth.uid);
    }

    match /race_day/{date} {
      // Race day coordination doc — admin starts/ends the day. Everyone
      // signed in can read the active state.
      allow read: if isSignedIn();
      allow write: if isAdmin();

      match /stints/{uid} {
        // Each athlete's stint on a given race day. Owner writes their own
        // (race-day stint logging from the Watch); team can read all stints
        // for the leaderboard.
        allow read: if isSignedIn();
        allow write: if isOwner(uid);
      }

      match /live/{uid} {
        // Live in-progress stint progress (every 15s while riding) so
        // teammates can spectate live laps/elapsed without the Watch.
        allow read: if isSignedIn();
        allow write: if isOwner(uid);
      }

      match /roster/{rosterId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }

      match /setup/{teamId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }
  }
}
