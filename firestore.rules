rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isGodAdmin() {
      // Bootstrap admins — can write config/adminPerms to grant delegated admins.
      // Keep more than one so losing access to a single address doesn't lock out governance.
      return isSignedIn() && request.auth.token.email in [
        'hearn.tenny@icloud.com'
      ];
    }

    function isAdmin() {
      // Delegated admins live in config/adminEmails — that's where the client
      // writes via admin.js:saveAdminEmails. An earlier version of these rules
      // referenced a `config/adminPerms` doc that the app never creates, so
      // delegated admins were silently blocked from every admin write.
      return isGodAdmin() || (
        isSignedIn()
        && exists(/databases/$(database)/documents/config/adminEmails)
        && request.auth.token.email in get(/databases/$(database)/documents/config/adminEmails).data.emails
      );
    }

    match /users/{userId} {
      // Any signed-in user may read profiles (leaderboards, team views).
      // Owner has full write. Admins may only update the coachPro*
      // entitlement fields — used by the Pro Requests admin tab to grant
      // or revoke Coach Pro on a specific user without the user having to
      // re-sign-in for the change to take effect.
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      // Owner deletes their own. Admins may also delete a user
      // profile — used by the Admin → Users → Orphan Accounts
      // tool to clean up spam signups (rec #76). Subcollections
      // (workouts, devices) are not cascaded; for a thorough
      // wipe, run firebase firestore:delete recursively from CLI.
      allow delete: if isOwner(userId) || isAdmin();
      // Owner may update their own profile, but cannot write the
      // privilege-gating fields. Was previously unrestricted, so a
      // user could `setDoc(users/<self>, {isCoach: true})` and bypass
      // every coach check (chat profanity bypass, race-day roster /
      // setup / alerts writes, send-push higher rate cap, etc.).
      // isCoach / isAdmin can only be set via the dedicated paths
      // below (admin entitlement update, head-coach promotion).
      allow update: if (
        isOwner(userId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'isCoach', 'isAdmin', 'coachProActive', 'coachProExempt',
          'coachProRequestStatus', 'coachProGrantedAt',
          'coachProGrantedBy', 'coachProRevokedAt'
        ])
      ) || (
        // Master account — already gated by isAdmin / isGodAdmin above
        // — keeps the broad self-update path so the master can set
        // their own isCoach flag during account bootstrap.
        isOwner(userId) && isGodAdmin()
      ) || (
        isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'coachProActive', 'coachProExempt', 'coachProRequestStatus',
          'coachProGrantedAt', 'coachProGrantedBy', 'coachProRevokedAt'
        ])
      ) || (
        // Head coach of a team may flip isCoach on a member of that same
        // team — the only field they can touch on someone else's profile.
        // "Head coach" = the user who created the team document.
        isSignedIn()
        && resource.data.teamId is string
        && request.auth.uid == get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.createdBy
        && userId in get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.members
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isCoach'])
      ) || (
        // Head coach can also assign / change a team member's active plan.
        // Only `activePlanId` is writeable through this path.
        isSignedIn()
        && resource.data.teamId is string
        && request.auth.uid == get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.createdBy
        && userId in get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.members
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['activePlanId'])
      );

      match /workouts/{workoutId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
        // Health-sync webhook writes via firebase-admin, which bypasses rules.
      }

      match /race_notes/{raceId} {
        // Per-rider race notes from coach-uploaded race reports. The
        // rider OWNS their notes (reads) and any signed-in user can
        // read them too (they're meant for the public profile view).
        // Writes are coach-only: head coach or co-coach of the rider's
        // current team.
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && (
          isAdmin() ||
          isOwner(userId) ||
          (
            resource == null
            && get(/databases/$(database)/documents/users/$(userId)).data.teamId is string
            && (
              get(/databases/$(database)/documents/teams/$(get(/databases/$(database)/documents/users/$(userId)).data.teamId)).data.createdBy == request.auth.uid
              ||
              request.auth.uid in get(/databases/$(database)/documents/teams/$(get(/databases/$(database)/documents/users/$(userId)).data.teamId)).data.coaches
            )
          ) ||
          (
            resource != null
            && get(/databases/$(database)/documents/users/$(userId)).data.teamId is string
            && (
              get(/databases/$(database)/documents/teams/$(get(/databases/$(database)/documents/users/$(userId)).data.teamId)).data.createdBy == request.auth.uid
              ||
              request.auth.uid in get(/databases/$(database)/documents/teams/$(get(/databases/$(database)/documents/users/$(userId)).data.teamId)).data.coaches
            )
          )
        );
        allow delete: if isAdmin() || isOwner(userId);
      }

      match /workout_routes/{workoutId} {
        // Imported route polylines (Garmin GPX/TCX, future Fitbit, etc.).
        // Owner reads + writes; teammates can read so the team feed can
        // render route maps.
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }

      match /checklist/{dateKey} {
        allow write: if isOwner(userId);
        // Coaches need to read checklist data to compute plan compliance
        // for athletes on their team. Read is broader than write so the
        // drill-in can show "4 of 6 sessions ticked this week."
        allow read: if isOwner(userId)
          || isAdmin()
          || (
            isSignedIn()
            && exists(/databases/$(database)/documents/users/$(userId))
            && get(/databases/$(database)/documents/users/$(userId)).data.teamId is string
            && (
              request.auth.uid == get(/databases/$(database)/documents/teams/$(get(/databases/$(database)/documents/users/$(userId)).data.teamId)).data.createdBy
              || request.auth.uid in get(/databases/$(database)/documents/teams/$(get(/databases/$(database)/documents/users/$(userId)).data.teamId)).data.coaches
            )
          );
      }

      match /customPlans/{planId} {
        allow read, write: if isOwner(userId);
      }

      match /raceLogs/{logId} {
        allow read, write: if isOwner(userId);
      }

      match /planOverrides/{planId} {
        // Reschedules of plan workouts when the athlete skips a day.
        // Owner-only — no coach/team visibility yet.
        allow read, write: if isOwner(userId);
      }

      match /raceResults/{resultId} {
        // Personal race results — owner-only.
        allow read, write: if isOwner(userId);
      }

      match /devices/{tokenId} {
        // Push notification tokens registered by the iOS app.
        allow read, write: if isOwner(userId);
      }

      match /photos/{photoId} {
        // Personal photo gallery — owner-only.
        allow read, write: if isOwner(userId);
      }
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      // Creator must put themselves in members (or be an admin creating on someone's behalf).
      // Prevents creating orphan teams with empty members arrays that no one can modify.
      allow create: if isSignedIn()
        && (request.auth.uid in request.resource.data.members || isAdmin());
      // Update permissions are scoped by role:
      //  - Head coach (createdBy) can edit name / description /
      //    inviteBlurb / features / subteams / coaches / members.
      //  - Any current member can leave (remove their own uid) or
      //    add their own uid; they cannot change other fields.
      //  - Non-member can self-join via members[] only (team-code flow).
      //  - Admins can do anything.
      // Was previously: any current member could rewrite the entire
      // doc, including renaming the team, changing createdBy, or
      // silently adding arbitrary uids to members[].
      allow update: if isAdmin()
        || (
          // Head coach: full update over a known set of editable keys.
          isSignedIn()
          && resource.data.createdBy == request.auth.uid
          && request.resource.data.members.size() > 0
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'name', 'description', 'inviteBlurb', 'features',
            'subteams', 'coaches', 'members',
            'weeklyIntent', 'weeklyIntentSetAt', 'weeklyIntentSetBy',
            'edition'
          ])
        )
        || (
          // Existing member: members-only update, must not boot anyone
          // else. Either add self, remove self, or no change in size
          // with same membership minus self being added/removed only.
          isSignedIn()
          && request.auth.uid in resource.data.members
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
          && request.resource.data.members.size() > 0
          && (
            // Adding self only (idempotent).
            (request.auth.uid in request.resource.data.members
             && request.resource.data.members.toSet().difference(resource.data.members.toSet())
                .hasOnly([]))
            ||
            // Leaving — must remove only self, no one else.
            (!(request.auth.uid in request.resource.data.members)
             && resource.data.members.toSet().difference(request.resource.data.members.toSet())
                .hasOnly([request.auth.uid])
             && request.resource.data.members.toSet().difference(resource.data.members.toSet())
                .hasOnly([]))
          )
        )
        || (
          // Non-member self-join: members-only update, adding only self.
          isSignedIn()
          && !(request.auth.uid in resource.data.members)
          && request.auth.uid in request.resource.data.members
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
          && request.resource.data.members.size() > 0
          && request.resource.data.members.toSet().difference(resource.data.members.toSet())
              .hasOnly([request.auth.uid])
        );
      allow delete: if (isSignedIn() && request.auth.uid in resource.data.members) || isAdmin();

      match /sharedPlans/{planId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.members;
      }

      // Lightweight broadcast notifications written by coaches (e.g. roster
      // updates during race day). Any team member can read; only members
      // can write. Audit found writes were silently failing — now allowed.
      match /alerts/{alertId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.members;
      }

      // Coach broadcast cues — short-lived signals like "start team
      // training now". Every team member reads them; only head coach
      // / co-coaches / admin can write.
      match /cues/{cueId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.members;
        allow write: if isAdmin()
          || (
            isSignedIn()
            && (
              get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy == request.auth.uid
              || request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.coaches
            )
          );
      }

      // Team chat / activity feed.
      // Schema: teams/{teamId}/chat/{messageId}
      //   uid, displayName, text, kind, createdAt
      //   kind: 'chat' (athlete chat), 'workout' (auto-post), 'coach' (broadcast),
      //         'system' (joined/left)
      //   broadcastPush: true if a coach asked iOS to push this message
      // Rules:
      //   - Read: any team member
      //   - Create: any team member, but uid must be self (no impersonation)
      //   - Update: only the author can edit their own (e.g. soft-delete)
      //     Coaches can flag any message as moderated (kind: 'coach' updates only)
      //   - Delete: author or head coach
      match /chat/{messageId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.members;
        // kind/displayName must be schema-pinned. Without this, any
        // team member could post `kind: 'coach', displayName: 'Coach'`
        // and the recipient UI would render their message in the
        // coach-broadcast banner — a plain impersonation channel.
        allow create: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.members
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.text is string
          // Text may be empty when the message carries an image; cap at 500.
          && request.resource.data.text.size() <= 500
          && (request.resource.data.text.size() > 0
              || (('imageUrl' in request.resource.data)
                  && request.resource.data.imageUrl is string
                  && request.resource.data.imageUrl.size() <= 1024))
          && request.resource.data.kind in ['chat', 'workout', 'coach', 'system', 'cheer', 'pr']
          // 'coach' kind only writable by an actual head coach of this
          // team, a co-coach (isCoach), OR a subteam captain
          // (team.subCoaches[]) — but a captain may only broadcast into
          // a subteam channel, never the whole team.
          && (request.resource.data.kind != 'coach'
              || request.auth.uid == get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy
              || (exists(/databases/$(database)/documents/users/$(request.auth.uid))
                  && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isCoach == true)
              || (('subCoaches' in get(/databases/$(database)/documents/teams/$(teamId)).data)
                  && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.subCoaches
                  && request.resource.data.subteamId is string
                  && request.resource.data.subteamId.size() > 0))
          // Author must use their own profile displayName so the
          // coach banner can't be impersonated by a member typing
          // someone else's name into displayName.
          && request.resource.data.displayName is string
          && request.resource.data.displayName.size() <= 80
          // subteamId is the channel scope. '' (or missing) = whole-team
          // channel; otherwise must be a string ≤ 64 chars referencing one
          // of the team's subteam ids. Membership enforcement is in the
          // app — rules just enforce shape so a malformed scope can't be
          // injected by a custom client.
          && (!('subteamId' in request.resource.data)
              || (request.resource.data.subteamId is string
                  && request.resource.data.subteamId.size() <= 64));
        allow update: if isSignedIn()
          && (
            // Author edits (e.g. soft-delete) or head-coach edits
            // (delete / pin) — full update allowed.
            resource.data.uid == request.auth.uid
            || request.auth.uid == get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy
            // Any team member may add/remove their own reaction — but
            // the ONLY field they may touch is `reactions`, so they
            // can't rewrite text / kind / displayName.
            || (
              request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.members
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
            )
            // A subteam captain may pin/unpin within their team — the
            // ONLY field they may touch is `pinned`.
            || (
              ('subCoaches' in get(/databases/$(database)/documents/teams/$(teamId)).data)
              && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.subCoaches
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pinned'])
            )
          );
        allow delete: if isSignedIn()
          && (resource.data.uid == request.auth.uid
              || request.auth.uid == get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy
              || isAdmin());
      }

      // Scheduled chat messages — coach/captain queues a message for a
      // future time; the deliverScheduledMessages Cloud Function moves
      // due ones into /chat. Schema: { uid, displayName, text, kind,
      // subteamId, broadcastPush, scheduledFor, createdAt }.
      match /scheduled/{schedId} {
        allow read, create, update, delete: if isSignedIn()
          && (
            request.auth.uid == get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy
            || (exists(/databases/$(database)/documents/users/$(request.auth.uid))
                && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isCoach == true)
            || (('subCoaches' in get(/databases/$(database)/documents/teams/$(teamId)).data)
                && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.subCoaches)
          );
      }

      // Subteam hierarchy: a head coach (the team's createdBy user) can
      // carve their team into named subteams (e.g. "Venom") and assign a
      // sub-coach. Athletes only see their own subteam's leaderboard.
      // Schema:
      //   teams/{teamId}/subteams/{subteamId}
      //     name: string
      //     subCoachUid: string (optional)
      //     members: [uid, ...]
      //     createdAt, updatedAt: serverTimestamp
      // Team gallery — shared photos uploaded by any team member.
      // Schema: teams/{teamId}/gallery/{photoId}
      //   uploadedBy: uid of the uploader (must match auth.uid on create)
      //   uploadedByName: display name
      //   dataUrl: base64 JPEG, ≤200 KB
      //   ts: ms timestamp
      //   caption: optional ≤140 char string
      // Read: any team member. Create: any team member, uid must be self.
      // Delete: uploader OR head coach (team creator) OR admin.
      // Race archive — coach-imported race results with AI summaries.
      // Read by team members, write by team coaches (head coach OR
      // anyone listed in the team's `coaches` array) OR admin.
      match /raceArchive/{eventId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.members;
        allow write: if isAdmin()
          || (isSignedIn()
              && (request.auth.uid == get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy
                  || (exists(/databases/$(database)/documents/users/$(request.auth.uid))
                      && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isCoach == true)));
      }

      match /gallery/{photoId} {
        allow read: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.members;
        // subteamId is optional — '' / missing means whole-team photo.
        // Client-side filtering decides which gallery a photo lands in;
        // rules just enforce shape + size + author.
        allow create: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.members
          && request.resource.data.uploadedBy == request.auth.uid
          && request.resource.data.dataUrl is string
          && request.resource.data.dataUrl.size() <= 220 * 1024
          && (!('subteamId' in request.resource.data)
              || (request.resource.data.subteamId is string
                  && request.resource.data.subteamId.size() <= 64));
        allow delete: if isSignedIn()
          && (resource.data.uploadedBy == request.auth.uid
              || request.auth.uid == get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy
              || isAdmin());
      }

      match /subteams/{subteamId} {
        // Everyone signed in can read so the leaderboard knows where each
        // member sits — filter UI does the visibility cut. (Cross-subteam
        // read is the same scope as cross-team-member read today.)
        allow read: if isSignedIn();
        // Only the head coach (team creator) OR an admin can write subteams.
        // Sub-coaches can update their own subteam (members + name) but
        // cannot create new subteams or reassign the sub-coach role.
        allow create, delete: if isAdmin()
          || (isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy);
        allow update: if isAdmin()
          || (isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy)
          || (isSignedIn() && resource.data.subCoachUid is string && request.auth.uid == resource.data.subCoachUid
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'members', 'updatedAt']));
      }
    }

    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /crashes/{id} {
      // Auto-captured client crashes (rec #64). The app writes here
      // on window.error / unhandledrejection so admins can triage
      // production issues without users having to report them.
      // Schema: { uid, displayName, email, page, version, ua,
      // message (≤2000), stack (≤4000), ts }.
      allow read, delete: if isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 2000
        && (!('stack' in request.resource.data)
            || (request.resource.data.stack is string && request.resource.data.stack.size() <= 4000));
    }

    match /feedback/{id} {
      // In-app feedback (rec #98). Any signed-in user can submit;
      // admins read + delete. Schema: { uid, displayName, email,
      // text (≤2000 chars), page, version, ts, role }.
      allow read, delete: if isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000;
    }

    match /roster/{emailKey} {
      // Pre-seeded roster entries from the admin Excel/CSV import.
      // Doc ID = sanitised lowercase email. Schema:
      //   { email, displayName, yearLevel, fitnessLevel,
      //     subteam, teamId, teamName, importedAt, importedBy }
      // Read: any signed-in user — the signup flow reads its own
      // entry right after account creation to pre-fill + auto-join.
      // Write: admins only (the importer runs from the admin panel).
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /global_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /team_invites/{inviteId} {
      // Direct-add invites issued by a head coach to an unassigned
      // user (teamId == null). Replaces share-a-code as the primary
      // onboarding path: coach picks the user from a list, this doc
      // is written, the invitee sees it on their team gate next time
      // they sign in and one-taps Accept.
      // Schema: { userId, teamId, teamName, teamCode, fromUid,
      //           fromName, ts }
      // Doc ID format: ${teamId}_${userId}
      allow read: if isSignedIn()
        && (
          // The invitee may read their own invites (used by the team
          // gate to surface them).
          resource.data.userId == request.auth.uid
          // Head coach who issued the invite may read it.
          || resource.data.fromUid == request.auth.uid
          || isAdmin()
        );
      allow create: if isSignedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.userId is string
        && request.resource.data.teamId is string
        // Only the head coach (createdBy) of the named team may issue
        // an invite — prevents drive-by spam.
        && request.auth.uid == get(/databases/$(database)/documents/teams/$(request.resource.data.teamId)).data.createdBy;
      // Invitee may delete (= dismiss) their own; head coach may
      // rescind.
      allow delete: if isSignedIn()
        && (
          resource.data.userId == request.auth.uid
          || resource.data.fromUid == request.auth.uid
          || isAdmin()
        );
    }

    match /coach_pro_requests/{uid} {
      // Coach Pro upgrade requests. Doc ID = user uid so each user has at
      // most one outstanding request. User creates/reads their own; admin
      // reads all + flips status (approved/exempt/denied) on review.
      allow read, create: if isOwner(uid);
      allow read, update, delete: if isAdmin();
    }

    match /league_requests/{requestId} {
      // Submitted by a coach when they want to start a new league. Admin
      // approves manually by creating the corresponding leagues/{id} doc.
      // Audit found this collection had no rules at all — writes were
      // silently denied.
      allow create: if isSignedIn()
        && request.resource.data.requestedBy == request.auth.uid;
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.requestedBy == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /approved_clubs/{clubId} {
      // Public list of approved clubs — used by the signup screen team
      // dropdown and the team-search UI. Anyone signed in can read; only
      // admins can approve a new club.
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /team_requests/{requestId} {
      // Coach signup requests for new teams. Coach creates one; admin
      // reads + approves/denies. We don't restrict the creator field at
      // create time — relying on the email field being self-attested
      // because there's no harm in a duplicate request.
      allow read, write: if isAdmin();
      allow create: if isSignedIn();
      allow read, delete: if isSignedIn() && resource.data.coachUid == request.auth.uid;
    }

    match /leagues/{leagueId} {
      // Cross-team / cross-school leagues. Anyone signed in reads to
      // see standings. Admin can do anything; the league creator can
      // update or delete their own league (audit found these were
      // silently failing).
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.createdBy == request.auth.uid);
    }

    // Watch pairing codes. The web app writes a doc here when the user
    // views Profile → Connect Watch; the Netlify function `watch-pair`
    // reads it (with admin SDK, bypasses rules) to validate the code
    // the Watch user typed.
    // - Create/update: signed-in user, but only if uid in body matches
    //   their auth uid (so a user can only claim their OWN code).
    // - Read/delete: server-side only (function uses admin); clients
    //   don't need to read these.
    match /watch_pair_codes/{code} {
      allow read: if false;
      allow create, update: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /race_archive/{raceId}/years/{year}/stints/{userId} {
      // Multi-year race archive — race-day stints get mirrored here
      // (in addition to race_day/{date}/stints/{uid}) so coaches can
      // query all stints for a given race across years without
      // scanning every calendar day. Doc ID = userId; collection-
      // level reads include the whole field. Read is broad (any
      // signed-in user — leaderboards across years) but writes are
      // gated to the doc owner so a teammate can't tamper with
      // someone else's archived stint.
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /race_archive/{raceId}/years/{year}/teams/{teamId} {
      // Coach-uploaded race report mirror. Any signed-in user can read
      // (so it surfaces in leaderboards + member sheets), but only
      // coaches of the team OR admin can write the doc.
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/teams/$(teamId))
          && (get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy == request.auth.uid
              || request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.coaches))
      );
      allow delete: if isAdmin();
    }

    match /race_day/{date} {
      // Race day coordination doc — admin starts/ends the day. Everyone
      // signed in can read the active state.
      allow read: if isSignedIn();
      allow write: if isAdmin();

      match /stints/{uid} {
        // Each athlete's stint on a given race day. Owner writes their own
        // (race-day stint logging from the Watch); team can read all stints
        // for the leaderboard.
        allow read: if isSignedIn();
        allow write: if isOwner(uid);
      }

      match /live/{uid} {
        // Live in-progress stint progress (every 15s while riding) so
        // teammates can spectate live laps/elapsed without the Watch.
        allow read: if isSignedIn();
        allow write: if isOwner(uid);
      }

      match /roster/{rosterId} {
        // Roster doc can be edited by an admin OR by any signed-in user
        // whose userProfile has isCoach == true. Race-day roster is a
        // coach activity (assigning drivers + stint durations), so
        // restricting it to platform admins locked out the team's own
        // head coach. Now coaches can manage their roster directly.
        allow read: if isSignedIn();
        allow write: if isAdmin()
          || (isSignedIn()
              && exists(/databases/$(database)/documents/users/$(request.auth.uid))
              && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isCoach == true);
      }

      match /setup/{teamId} {
        // Same scope as roster — head coach configures the field/track
        // setup for their team's race day.
        allow read: if isSignedIn();
        allow write: if isAdmin()
          || (isSignedIn()
              && exists(/databases/$(database)/documents/users/$(request.auth.uid))
              && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isCoach == true);
      }

      match /alerts/{alertId} {
        // Coaches/admins post race-day alerts; everyone reads.
        allow read: if isSignedIn();
        allow create: if isAdmin()
          || (isSignedIn()
              && exists(/databases/$(database)/documents/users/$(request.auth.uid))
              && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isCoach == true);
        allow update, delete: if isAdmin();
      }
    }
  }
}
