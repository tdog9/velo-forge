<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.developer.healthkit</key>
	<true/>
	<key>com.apple.developer.healthkit.background-delivery</key>
	<true/>
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.403productions.turboprep</string>
	</array>
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.403productions.turboprep</string>
	</array>
	<!-- Push notifications. "production" for TestFlight + App Store
	     builds (uses api.push.apple.com). Flip to "development" only
	     when running Xcode-signed builds against the APNs sandbox. -->
	<key>aps-environment</key>
	<string>production</string>
	<!-- StoreKit / In-App Purchase doesn't need a separate entitlement; the
	     capability is enabled automatically once the app is signed by a team
	     enrolled in the Apple Developer Program. -->
	<!-- Associated Domains — lets https://turboprep.app/* links open the
	     iOS app instead of Safari. The matching apple-app-site-association
	     file lives at /.well-known/apple-app-site-association on the web
	     bundle and is served as application/json (see netlify.toml). -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:turboprep.app</string>
		<string>webcredentials:turboprep.app</string>
	</array>
</dict>
</plist>
